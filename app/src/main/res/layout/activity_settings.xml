<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/btn_back_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="@android:color/transparent"
                android:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingStart="12dp"/>
        </LinearLayout>

        <!-- Font -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="FONT" android:textColor="#333333" android:textSize="11sp"
            android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>

        <Spinner android:id="@+id/font_spinner" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="#111114"
            android:layout_marginBottom="20dp" android:popupBackground="#111114"/>

        <!-- Font size -->
        <TextView android:id="@+id/font_size_label" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Font Size: 15sp" android:textColor="#FFFFFF" android:textSize="15sp"
            android:textStyle="bold" android:layout_marginBottom="8dp"/>

        <SeekBar android:id="@+id/font_size_slider" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF" android:layout_marginBottom="20dp"/>

        <!-- Dark mode -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#111114" android:padding="14dp" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Dark Mode" android:textColor="#FFFFFF" android:textSize="15sp"/>
            <Switch android:id="@+id/dark_mode_toggle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Show hidden -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="#111114" android:padding="14dp" android:layout_marginBottom="20dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Show Hidden Files" android:textColor="#FFFFFF" android:textSize="15sp"/>
            <Switch android:id="@+id/show_hidden_toggle" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Sort -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SORT BY" android:textColor="#333333" android:textSize="11sp"
            android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>

        <Spinner android:id="@+id/sort_spinner" android:layout_width="match_parent"
            android:layout_height="48dp" android:background="#111114"
            android:layout_marginBottom="20dp" android:popupBackground="#111114"/>

        <!-- Wallpaper -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="BACKGROUND WALLPAPER" android:textColor="#333333" android:textSize="11sp"
            android:letterSpacing="0.12" android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btn_pick_wallpaper" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="Choose Wallpaper"
            android:textColor="#FFFFFF" android:backgroundTint="#1A1A1E"
            android:layout_marginBottom="8dp"/>

        <Button android:id="@+id/btn_clear_wallpaper" android:layout_width="match_parent"
            android:layout_height="50dp" android:text="Clear Wallpaper"
            android:textColor="#888888" android:backgroundTint="#1A1A1E"/>

    </LinearLayout>
</ScrollView>